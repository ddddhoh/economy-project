        <div class="post-detail-date" id="detail-date"></div>
      </div>
      <div class="post-detail-title" id="detail-title"></div>
      <div class="post-detail-body" id="detail-body"></div>
      <div class="post-detail-delete">
        <button class="btn-delete" onclick="deletePost()">삭제</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<footer>
  <div class="footer-logo">책온 — BOOK TEMPERATURE</div>
  <p>책으로 온도를 높이다 · 경제책 읽기 프로젝트 6개월</p>
</footer>


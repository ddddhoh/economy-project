        <label class="field-label">이름</label>
        <input type="text" class="field-input" id="write-name" placeholder="예: 김동현">
      </div>
      <div class="field-group">
        <label class="field-label">제목</label>
        <input type="text" class="field-input" id="write-title" placeholder="결과물 제목을 입력하세요">
      </div>
      <div class="field-group">
        <label class="field-label">내용</label>
        <textarea class="field-textarea" id="write-content" placeholder="독후 에세이, 분석 내용, 선언문 등 자유롭게 작성하세요"></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeWriteModal()">취소</button>
        <button class="btn-submit" id="submit-btn" onclick="submitPost()">등록하기</button>
      </div>
    </div>
  </div>
</div>

<!-- DETAIL MODAL -->
<div class="modal-overlay" id="detail-modal">
  <div class="modal">
    <div class="modal-header">
      <div>
        <div class="modal-title" id="detail-modal-book"></div>

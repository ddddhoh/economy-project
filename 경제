    <div id="member-detail-area"></div>
  </div>
</div>

<!-- WRITE MODAL -->
<div class="modal-overlay" id="write-modal">
  <div class="modal">
    <div class="modal-header">
      <div>
        <div class="modal-title">결과물 올리기</div>

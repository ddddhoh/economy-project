  { id:'b2', month:2, step:1, stepLabel:'Step 1', title:'경제 기사 궁금증 300문 300답', author:'곽해선', theme:'경제 뉴스를 읽을 수 있는 사람 되기', colorClass:'step1-color', tagClass:'tag-step1' },
  { id:'b3', month:3, step:2, stepLabel:'Step 2', title:'월가의 영웅', author:'피터 린치', theme:'좋은 기업을 보는 눈 기르기', colorClass:'step2-color', tagClass:'tag-step2' },
  { id:'b4', month:4, step:2, stepLabel:'Step 2', title:'돈의 심리학', author:'모건 하우절', theme:'돈과 감정의 관계 이해하기', colorClass:'step2-color', tagClass:'tag-step2' },
  { id:'b5', month:5, step:3, stepLabel:'Step 3', title:'돈의 공식', author:'윌리엄 번스타인', theme:'자산배분 이해하고 계획 세우기', colorClass:'step3-color', tagClass:'tag-step3' },
  { id:'b6', month:6, step:3, stepLabel:'Step 3', title:'부의 인문학', author:'브라운스톤', theme:'돈을 삶과 연결하고 실행 계획 세우기', colorClass:'step3-color', tagClass:'tag-step3' }
];

const MEMBERS = ['동현', '지수', '민준', '서연', '예진', '준혁', '하은', '도윤', '수아', '민서'];

// ── STATE ──
let allPosts = [];
let currentView = 'books';
let writeTargetBookId = null;
let detailTargetPost = null;
let selectedMember = MEMBERS[0];

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ── FETCH ALL POSTS ──
async function fetchPosts() {
  const { data, error } = await sb.from('posts').select('*').order('created_at', { ascending: false });
  if (error) { console.error(error); return; }
  allPosts = data || [];
}

// ── VIEW SWITCH ──
function setView(v) {
  currentView = v;
  document.getElementById('view-books').style.display = v === 'books' ? '' : 'none';
  document.getElementById('view-members').style.display = v === 'members' ? '' : 'none';
  ['nav-books','nav-members'].forEach(id => document.getElementById(id).classList.remove('active'));
  ['vb-books','vb-members'].forEach(id => document.getElementById(id).classList.remove('active'));
  document.getElementById(v === 'books' ? 'nav-books' : 'nav-members').classList.add('active');
  document.getElementById(v === 'books' ? 'vb-books' : 'vb-members').classList.add('active');
  if (v === 'books') renderBooksView();
  else renderMembersView();
}

// ── BOOKS VIEW ──
function renderBooksView() {
  const grid = document.getElementById('books-grid');
  grid.innerHTML = BOOKS.map(book => {
    const bookPosts = allPosts.filter(p => p.book_id === book.id);
    const postItems = bookPosts.length
      ? bookPosts.map(p => `
        <div class="post-item" onclick="openDetail('${p.id}')">
          <div class="post-avatar">${p.name.charAt(0)}</div>
          <div class="post-info">
            <div class="post-name">${esc(p.name)}</div>
            <div class="post-excerpt">${esc(p.title)}</div>
          </div>
          <div class="post-date">${formatDate(p.created_at)}</div>
        </div>`).join('')
      : `<div class="empty-posts"><span>✍️</span>아직 결과물이 없어요<br>첫 번째로 올려보세요!</div>`;
    return `
    <div class="book-card">
      <div class="book-card-header">
        <div class="book-month-badge ${book.colorClass}">${book.month}<span>개월차</span></div>
        <div class="book-meta">
          <span class="book-step-tag ${book.tagClass}">${book.stepLabel} · ${book.month}개월차</span>
          <div class="book-title">《${book.title}》</div>
          <div class="book-author">${book.author}</div>
        </div>
      </div>
      <div class="book-theme">"${book.theme}"</div>
      <div class="book-posts">
        <div class="book-posts-header">
          <span class="book-posts-title">결과물 ${bookPosts.length}개</span>
          <button class="add-post-btn" onclick="openWrite('${book.id}', event)">+ 올리기</button>
        </div>
        <div class="post-list">${postItems}</div>
      </div>
    </div>`;
  }).join('');
}

// ── MEMBERS VIEW ──
function renderMembersView() {
  const bar = document.getElementById('member-select-bar');
  bar.innerHTML = `<div class="member-select-label">멤버를 선택하세요</div>` +
    MEMBERS.map(m => `
      <button class="member-chip ${m === selectedMember ? 'selected' : ''}" onclick="selectMember('${m}')">
        <div class="chip-avatar">${m.charAt(0)}</div>${m}
      </button>`).join('');
  renderMemberDetail();
}

function selectMember(name) {
  selectedMember = name;
  renderMembersView();
}

function renderMemberDetail() {
  const area = document.getElementById('member-detail-area');
  const memberPosts = allPosts.filter(p => p.name === selectedMember);
  const doneCount = [...new Set(memberPosts.map(p => p.book_id))].length;
  const progressPct = Math.round(doneCount / BOOKS.length * 100);

  const booksHtml = BOOKS.map(book => {
    const post = memberPosts.find(p => p.book_id === book.id);
    const postHtml = post
      ? `<div class="member-post-area has-post" onclick="openDetail('${post.id}')">
          <div class="member-post-title">📄 ${esc(post.title)}</div>
          <div class="member-post-body">${esc(post.content.substring(0,100))}${post.content.length>100?'…':''}</div>
        </div>`
      : `<div class="member-post-area" onclick="openWrite('${book.id}', event, '${selectedMember}')">
          <div class="member-post-empty">✍️ 아직 작성하지 않았어요<br><small>클릭하여 결과물 올리기</small></div>
        </div>`;
    return `
    <div class="member-book-row">
      <div class="member-book-row-header">
        <div class="book-month-badge ${book.colorClass}" style="min-width:38px;height:38px;font-size:0.9rem;">${book.month}<span>개월</span></div>
        <div class="book-meta">
          <span class="book-step-tag ${book.tagClass}" style="font-size:0.62rem;">${book.stepLabel}</span>
          <div class="book-title" style="font-size:0.92rem;">《${book.title}》</div>
          <div class="book-author" style="font-size:0.72rem;">${book.author}</div>
        </div>
      </div>
      ${postHtml}
    </div>`;
  }).join('');

  area.innerHTML = `
    <div class="member-progress">
      <div class="member-progress-header">
        <div class="member-big-avatar">${selectedMember.charAt(0)}</div>
        <div class="member-name-block">
          <div class="member-name">${selectedMember}</div>
          <div class="member-stat">완료한 책 <strong>${doneCount} / 6권</strong> · 진행률 <strong>${progressPct}%</strong></div>
        </div>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-label"><strong>전체 진행률</strong><span>${doneCount}/6 완료</span></div>
        <div class="progress-track"><div class="progress-fill" style="width:${progressPct}%"></div></div>
      </div>
    </div>
    <div class="member-books-grid">${booksHtml}</div>`;
}

// ── WRITE MODAL ──
function openWrite(bookId, e, prefillName) {
  if (e) e.stopPropagation();
  writeTargetBookId = bookId;
  const book = BOOKS.find(b => b.id === bookId);
  document.getElementById('write-modal-sub').textContent = `《${book.title}》 · ${book.author}`;
  document.getElementById('write-name').value = prefillName || '';
  document.getElementById('write-title').value = '';
  document.getElementById('write-content').value = '';
  document.getElementById('write-modal').classList.add('open');
}
function closeWriteModal() {
  document.getElementById('write-modal').classList.remove('open');
  writeTargetBookId = null;
}
async function submitPost() {
  const name = document.getElementById('write-name').value.trim();
  const title = document.getElementById('write-title').value.trim();
  const content = document.getElementById('write-content').value.trim();
  if (!name || !title || !content) { alert('이름, 제목, 내용을 모두 입력해주세요.'); return; }
  const btn = document.getElementById('submit-btn');
  btn.disabled = true; btn.textContent = '등록 중...';
  const { error } = await sb.from('posts').insert({ book_id: writeTargetBookId, name, title, content });
  btn.disabled = false; btn.textContent = '등록하기';
  if (error) { alert('등록 중 오류가 발생했습니다.'); console.error(error); return; }
  await fetchPosts();
  closeWriteModal();
  if (currentView === 'books') renderBooksView();
  else renderMemberDetail();
  showToast('✅ 결과물이 등록됐어요!');
}

// ── DETAIL MODAL ──
function openDetail(postId) {
  const p = allPosts.find(x => x.id === postId);
  if (!p) return;
  detailTargetPost = p;
  const book = BOOKS.find(b => b.id === p.book_id);
  document.getElementById('detail-modal-book').textContent = `《${book.title}》`;
  document.getElementById('detail-avatar').textContent = p.name.charAt(0);
  document.getElementById('detail-author').textContent = p.name;
  document.getElementById('detail-book-info').textContent = `${book.author} · ${book.stepLabel} ${book.month}개월차`;
  document.getElementById('detail-date').textContent = formatDate(p.created_at);
  document.getElementById('detail-title').textContent = p.title;
  document.getElementById('detail-body').textContent = p.content;
  document.getElementById('detail-modal').classList.add('open');
}
function closeDetailModal() {
  document.getElementById('detail-modal').classList.remove('open');
  detailTargetPost = null;
}
async function deletePost() {
  if (!detailTargetPost) return;
  if (!confirm('이 결과물을 삭제할까요?')) return;
  const { error } = await sb.from('posts').delete().eq('id', detailTargetPost.id);
  if (error) { alert('삭제 중 오류가 발생했습니다.'); return; }
  await fetchPosts();
  closeDetailModal();
  if (currentView === 'books') renderBooksView();
  else renderMemberDetail();
  showToast('🗑️ 삭제됐어요.');
}

document.getElementById('write-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeWriteModal(); });
document.getElementById('detail-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeDetailModal(); });

// ── UTILS ──
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function formatDate(iso) {
  const d = new Date(iso);
  return `${d.getMonth()+1}/${d.getDate()}`;
}

// ── INIT ──
(async () => {
  document.getElementById('books-grid').innerHTML = '<div class="loading-spinner">불러오는 중...</div>';
  await fetchPosts();
  renderBooksView();
})();
</script>
</body>
</html>

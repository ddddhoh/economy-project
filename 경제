    <div class="post-detail-content">
      <div class="post-detail-meta">
        <div style="width:34px;height:34px;border-radius:50%;background:var(--ink);color:var(--gold);font-size:0.8rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;" id="detail-avatar"></div>
        <div>
          <div class="post-detail-author" id="detail-author"></div>
          <div class="post-detail-book" id="detail-book-info"></div>
